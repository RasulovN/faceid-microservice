# ============================================================
# FaceID Face Service (FastAPI + InsightFace) — Environment
# Servis O'Z papkasidan ishga tushganda shu faylni o'qiydi:
#   cp .env.example .env
# (Docker Compose orqali — loyiha ildizidagi .env ishlatiladi.)
# Kalit nomlari app/config.py (pydantic-settings) bilan bir xil.
# ============================================================

# ---------- Xavfsizlik ----------
# Node backend bilan BIR XIL bo'lsin (header: X-Internal-Api-Key).
# Bo'sh qoldirilsa HAR bir so'rov rad etiladi.
INTERNAL_API_KEY=change_me_internal_api_key

# ---------- Moslik chegaralari ----------
FACE_MATCH_THRESHOLD=0.5
LIVENESS_THRESHOLD=0.7
FACE_QUALITY_THRESHOLD=0.35

# ---------- Servis ----------
FACE_USE_GPU=false
FACE_SERVICE_PORT=8000
LOG_LEVEL=INFO

# ---------- DB (pgvector 1:N identify uchun, read-only) ----------
# Bo'sh bo'lsa /identify o'chiriladi (extract/verify/liveness ishlayveradi)
FACE_SERVICE_DATABASE_URL=postgresql://faceid:faceid_dev_password@localhost:5432/faceid
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# ---------- InsightFace modeli ----------
FACE_MODEL_NAME=buffalo_l
FACE_MODEL_ROOT=~/.insightface
FACE_DET_SIZE=640
# Real-time /analyze uchun ALOHIDA yengil engine: kichik detektor kirishi +
# faqat detection/landmark modullari (ArcFace har kadrda ISHLAMAYDI — 2-3x tez).
ANALYZE_DET_SIZE=320
ANALYZE_LITE_ENGINE=true

# ---------- Liveness (Silent-Face MiniFASNet ONNX ANSAMBL) ----------
# Birinchi startda URL'lardan yuklanadi; yuklab bo'lmagan model o'tkazib
# yuboriladi, BITTASI ham yuklanmasa "disabled" rejim (score=1.0).
LIVENESS_MODEL_PATH=models/AntiSpoofing_bin_1.5_128.onnx
LIVENESS_INPUT_SIZE=128
LIVENESS_BBOX_SCALE=1.5
LIVENESS_LIVE_INDEX=0
LIVENESS_DOWNLOAD_TIMEOUT=60
# Ikkinchi (print/replay-maxsus) model — ekran/qog'oz hujumlariga kuchli.
# Bo'sh qoldirilsa ansambl faqat birinchi modelda ishlaydi.
#LIVENESS_MODEL2_URL=https://github.com/hairymax/Face-AntiSpoofing/raw/main/saved_models/AntiSpoofing_print-replay_1.5_128.onnx
LIVENESS_MODEL2_PATH=models/AntiSpoofing_print-replay_1.5_128.onnx
LIVENESS_MODEL2_LIVE_INDEX=0
# Ansambl aggregatsiyasi: min (qattiqroq, default) | mean (yumshoqroq)
LIVENESS_AGGREGATION=min

# ---------- Burst (/verify-live — mobil jonlilik tekshiruvi) ----------
# Kamida shuncha kadrda yuz bo'lishi shart (aks holda FACE_NOT_FOUND)
BURST_MIN_VALID_FRAMES=3
BURST_MAX_FRAMES=8
# Kadrlararo "bir odam" izchillik chegarasi (min juftlik cosine sim)
BURST_CONSISTENCY_THRESHOLD=0.55
# "turn" challenge: burst davomida bosh burilishi (yaw) diapazoni, gradus
CHALLENGE_YAW_RANGE_DEG=12
# Blink (EAR): yopiq/ochiq ko'z chegaralari — challenge'ga muqobil dalil.
# Mobil klient blink paytida suratga oladi (takePhoto kechikishiga tolerantli).
BLINK_EAR_CLOSE=0.20
BLINK_EAR_OPEN=0.26
